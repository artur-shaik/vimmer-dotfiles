#!/usr/bin/python3

"""Saver module for xsecurelock.

It displays a background image, clock and weather. Configuration is
done through environment variables:

 - XSECURELOCK_SAVER_IMAGE: path to the background image to use
 - XSECURELOCK_SAVER_WEATHER: path to weather text
 - XSECURELOCK_SAVER_FONT: font family to use to display clock and weather
 - XSECURELOCK_SAVER_CLOCK_FONT_SIZE: font size to use to display clock
 - XSECURELOCK_SAVER_WEATHER_FONT_SIZE: font size to use to display weather

"""

# In case I want to put a video instead of an image:
# https://gist.github.com/NBonaparte/89fb1b645c99470bc0f6. Check
# `bin/wallpaper' for some sources.

import os
import types
import datetime
import glob
import re
import socket
import subprocess
import threading
import time
import cairo
import gi

gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, Gdk, GdkX11, GLib, GdkPixbuf, Gio


def compute_roles(widget, ctx, x, y, w, h):
    """Роль монитора по геометрии: где часы (основной), где инфо (внешний если есть).

    ash: каждый saver-процесс свой монитор знает (xsecurelock плодит по одному
    на экран). Детерминированно, без сокет-гонки: часы на primary, виджеты на
    info-мониторе = внешний при мульти-сетапе, иначе тот же (справа).
    """
    try:
        display = widget.get_display()
        n = display.get_n_monitors()
        geoms = [
            (lambda g: (g.x, g.y, g.width, g.height))(
                display.get_monitor(i).get_geometry()
            )
            for i in range(n)
        ]
        prim = display.get_primary_monitor()
        pg = (prim or display.get_monitor(0)).get_geometry()
        ptl = (pg.x, pg.y)
        if n > 1:
            others = [g for g in geoms if (g[0], g[1]) != ptl]
            ig = (
                max(others, key=lambda g: g[0])
                if others
                else (pg.x, pg.y, pg.width, pg.height)
            )
        else:
            ig = (pg.x, pg.y, pg.width, pg.height)
        itl = (ig[0], ig[1])
        cx, cy = x + w // 2, y + h // 2
        mine = next(
            (
                (g[0], g[1])
                for g in geoms
                if g[0] <= cx < g[0] + g[2] and g[1] <= cy < g[1] + g[3]
            ),
            (x, y),
        )
        ctx.is_clock = mine == ptl
        ctx.is_info = mine == itl
    except Exception:
        ctx.is_clock = True
        ctx.is_info = True


def on_win_realize(widget, ctx):
    """On realization, embed into XSCREENSAVER_WINDOW and remember parent position."""
    parent_wid = int(os.getenv("XSCREENSAVER_WINDOW", 0))
    if not parent_wid:
        return
    parent = GdkX11.X11Window.foreign_new_for_display(widget.get_display(), parent_wid)
    x, y, w, h = parent.get_geometry()
    ctx.position = x, y
    compute_roles(widget, ctx, x, y, w, h)
    window = widget.get_window()
    window.resize(w, h)
    window.reparent(parent, 0, 0)


def on_win_draw(widget, cctx, ctx):
    """Draw background image, scaled to COVER this window (per-monitor).

    ash: раньше кропил subpixbuf по АБСОЛЮТНОЙ позиции монитора — обои 1920px
    шириной, второй монитор с x=1920 уходил за край картинки → чёрный экран.
    Теперь каждое окно saver'а заполняет обои по cover (как feh --bg-fill),
    независимо от позиции/размера → работает на любом числе мониторов.
    """
    wwidth, wheight = widget.get_size()
    scale = widget.get_scale_factor()

    cctx.set_operator(cairo.OPERATOR_SOURCE)
    if not ctx.background:
        cctx.set_source_rgba(0, 0, 0, 1)
        cctx.paint()
        return

    iw = ctx.background.get_width()
    ih = ctx.background.get_height()
    dw = wwidth * scale
    dh = wheight * scale
    s = max(dw / iw, dh / ih)  # cover: заполнить, обрезав лишнее
    ox = (dw - iw * s) / 2
    oy = (dh - ih * s) / 2

    cctx.save()
    cctx.scale(1 / scale, 1 / scale)
    cctx.translate(ox, oy)
    cctx.scale(s, s)
    Gdk.cairo_set_source_pixbuf(cctx, ctx.background, 0, 0)
    cctx.paint()
    cctx.restore()


def on_overlay_draw(widget, cctx, ctx):
    """Draw overlay: часы+дата на основном мониторе, инфо-виджеты на info-мониторе
    (внешний если есть, иначе тот же), справа."""
    wwidth, wheight = widget.get_parent().get_size()
    cctx.set_operator(cairo.OPERATOR_OVER)

    def draw(what):
        x, y = cctx.get_current_point()
        cctx.set_source_rgba(0, 0, 0, 0.3)
        cctx.move_to(x + 2, y + 2)
        cctx.show_text(what)
        cctx.set_source_rgb(1, 1, 1)
        cctx.move_to(x, y)
        cctx.show_text(what)

    # Clock (только на основном мониторе)
    if ctx.is_clock and ctx.clock:
        time, date = ctx.clock

        # Time (ash: вес NORMAL — семейство уже Light/Poppins, BOLD его забивал)
        cctx.select_font_face(
            ctx.font_family, cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_NORMAL
        )
        cctx.set_font_size(ctx.clock_font_size)
        _, _, twidth, theight, _, _ = cctx.text_extents(re.sub(r"\d", "8", time))
        cctx.move_to(wwidth // 2 - twidth // 2, wheight // 3)
        draw(time)

        # Date
        cctx.select_font_face(
            ctx.font_family, cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_NORMAL
        )
        cctx.set_font_size(ctx.clock_font_size // 3)
        _, _, twidth, theight, _, _ = cctx.text_extents(date)
        cctx.move_to(wwidth // 2 - twidth // 2, wheight // 3 + theight * 1.5)
        draw(date)

    # Weather
    # We can have polybar markups in it. We assume %{Tx} means to use
    # Font Awesome 6 and we ignore font color change. The parsing is
    # quite basic.
    if ctx.is_clock and ctx.weather:
        data = re.sub(r"%{F[#\d+-]+?}", "", ctx.weather)
        data = re.split(r"(%{T[1-9-]})", data)
        font = ctx.font_family
        cctx.move_to(20, wheight - 20)
        for chunk in data:
            if chunk == "%{T-}":
                font = ctx.font_family
                continue
            elif chunk.startswith("%{T"):
                font = "Font Awesome 6 Pro"
                continue
            elif not chunk:
                continue
            cctx.select_font_face(
                font, cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_NORMAL
            )
            cctx.set_font_size(ctx.weather_font_size)
            draw(chunk)

    # ash: инфо-виджеты (батарея/музыка/задачи) — info-монитор, нижний-ПРАВЫЙ
    # угол, стопкой. Иконка nerd-шрифтом, текст info-шрифтом (+ кириллица).
    info = getattr(ctx, "info", None)
    if ctx.is_info and info:
        isize = min(14, ctx.clock_font_size // 6)
        gap = 16
        line_h = int(isize * 1.7)
        margin = 60
        y = wheight - 40
        for icon, text in reversed(info):
            # ширины иконки и текста — для правого выравнивания
            cctx.select_font_face(
                ctx.icon_font, cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_NORMAL
            )
            cctx.set_font_size(isize)
            iadv = cctx.text_extents(icon)[4]
            cctx.select_font_face(
                ctx.info_font, cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_NORMAL
            )
            cctx.set_font_size(isize)
            tw = cctx.text_extents(text)[4]
            x = wwidth - margin - (iadv + gap + tw)
            # иконка
            cctx.select_font_face(
                ctx.icon_font, cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_NORMAL
            )
            cctx.set_font_size(isize)
            cctx.move_to(x, y)
            draw(icon)
            # текст
            cctx.select_font_face(
                ctx.info_font, cairo.FONT_SLANT_NORMAL, cairo.FONT_WEIGHT_NORMAL
            )
            cctx.set_font_size(isize)
            cctx.move_to(x + iadv + gap, y)
            draw(text)
            y -= line_h


def on_background_change(monitor, f1, f2, event, ctx):
    """Update background when changed."""
    if event not in (
        Gio.FileMonitorEvent.CHANGES_DONE_HINT,
        Gio.FileMonitorEvent.RENAMED,
    ):
        return
    try:
        new_background = GdkPixbuf.Pixbuf.new_from_file(ctx.background_image)
    except Exception:
        return
    ctx.background = new_background
    ctx.window.queue_draw()


def on_clock_change(ctx):
    """Clock may have changed. Update it.

    We are checking more often than once a minute because we want to
    update the clock swiftly after suspend. An alternative would be to
    listen to PrepareForSleep signal from org.freedesktop.login1, but
    this is more complex.

    """
    now = datetime.datetime.now()
    new_clock = now.strftime("%H:%M")
    if not ctx.clock or new_clock != ctx.clock[0]:
        ctx.clock = (new_clock, now.strftime("%A %-d %B"))
        ctx.overlay.queue_draw()
    # ash: тикаем на каждом мониторе (роли по геометрии, рисует только is_clock).
    # Раньше тут была сокет-выборка leader'а — убрана.
    GLib.timeout_add(min(60 - now.second, 3) * 1000, on_clock_change, ctx)


def on_weather_change(monitor, f1, f2, event, ctx):
    """Weather file has changed."""
    if event not in (
        Gio.FileMonitorEvent.CHANGES_DONE_HINT,
        Gio.FileMonitorEvent.RENAMED,
    ):
        return
    try:
        with open(ctx.weather_file) as wfile:
            ctx.weather = wfile.read()
        ctx.overlay.queue_draw()
    except Exception:
        pass


# ──────────────────────────────────────────────────────────────────────────
# ash: инфо-виджеты на локскрине — батарея / музыка (mpd) / задачи (taskwarrior).
# Каждый возвращает (icon, text) или None. Иконки — глифы Nerd Font (FontAwesome).
# Сбор в фоновом потоке (_gather), чтобы subprocess не морозил GTK-цикл.
# ──────────────────────────────────────────────────────────────────────────


def _battery(ctx):
    bats = sorted(glob.glob("/sys/class/power_supply/BAT*"))
    if not bats:
        return None
    b = bats[0]
    cap = int(open(os.path.join(b, "capacity")).read().strip())
    status = open(os.path.join(b, "status")).read().strip().lower()
    if status in ("charging", "full"):
        icon = chr(0xF0E7)  # nf bolt
    else:
        # fa battery: f244 empty .. f240 full
        icon = [chr(c) for c in (0xF244, 0xF243, 0xF242, 0xF241, 0xF240)][
            min(4, cap // 25)
        ]
    return (icon, "%d%%" % cap)


def _music(ctx):
    env = dict(os.environ)
    if ctx.mpd_host:
        env["MPD_HOST"] = ctx.mpd_host
    # plain `mpc current` = пусто когда не играет (с -f выдаёт " — " даже на стопе)
    out = subprocess.run(
        ["mpc", "current"],
        capture_output=True,
        text=True,
        timeout=2,
        env=env,
    )
    s = out.stdout.strip()
    if not s:
        return None
    if len(s) > 60:
        s = s[:59] + "…"
    return (chr(0xF001), s)  # music note


def _tasks(ctx):
    out = subprocess.run(
        [
            "task",
            "rc.verbose=nothing",
            "rc.gc=off",
            "status:pending",
            "due.before:tomorrow",
            "count",
        ],
        capture_output=True,
        text=True,
        timeout=3,
    )
    n = out.stdout.strip() or "0"
    if not n.isdigit() or n == "0":
        return None
    return (chr(0xF0AE), "%s на сегодня" % n)  # tasks


def _apply_info(ctx, items):
    ctx.info = items
    ctx.overlay.queue_draw()
    return False


def _gather(ctx):
    items = []
    for fn in (_battery, _music, _tasks):
        try:
            r = fn(ctx)
        except Exception:
            r = None
        if r:
            items.append(r)
    GLib.idle_add(_apply_info, ctx, items)


def poll_info(ctx):
    """Запустить сбор инфо в фоне (только на info-мониторе). Повторяется."""
    if ctx.is_info:
        threading.Thread(target=_gather, args=(ctx,), daemon=True).start()
    return True


if __name__ == "__main__":
    ctx = types.SimpleNamespace()
    with open("/home/ash/.cache/wal/current_wall", "r") as f:
        _src_wall = f.read().strip()
    # ash: блюр фона (как gh0stzk i3lock). Блюрим ОДИН раз в кэш, если обои
    # новее кэша; saver грузит готовую блюр-версию (на каждый draw не блюрим).
    # Fast-trick: downscale -> blur -> upscale (вдвое быстрее полного gaussian).
    # Радиус через XSECURELOCK_SAVER_BLUR (на downscaled, дефолт 0x4). Пусто/0 = без блюра.
    _blur_cache = os.path.expanduser("~/.cache/wal/lock_blur.jpg")
    _blur = os.getenv("XSECURELOCK_SAVER_BLUR", "0x4")
    ctx.background_image = _src_wall
    if _src_wall and _blur not in ("", "0"):
        try:
            if not os.path.exists(_blur_cache) or os.path.getmtime(
                _src_wall
            ) > os.path.getmtime(_blur_cache):
                subprocess.run(
                    [
                        "magick",
                        _src_wall,
                        "-scale",
                        "25%",
                        "-blur",
                        _blur,
                        "-resize",
                        "400%",
                        _blur_cache,
                    ],
                    check=True,
                    timeout=20,
                )
            if os.path.exists(_blur_cache):
                ctx.background_image = _blur_cache
        except Exception:
            pass  # блюр не вышел — остаёмся на резком фоне
    ctx.clock_font_size = int(os.getenv("XSECURELOCK_SAVER_CLOCK_FONT_SIZE", 190))
    ctx.weather_font_size = int(os.getenv("XSECURELOCK_SAVER_CLOCK_FONT_SIZE", 40))
    ctx.weather_file = os.getenv("XSECURELOCK_SAVER_WEATHER", None)
    ctx.font_family = os.getenv("XSECURELOCK_SAVER_FONT", "JetBrainsMono NF Thin")
    ctx.background = None
    ctx.weather = None
    ctx.clock = None
    ctx.position = (0, 0)
    # ash: роли монитора — уточняются в on_win_realize по геометрии. Дефолт True/True
    # = одиночный монитор (нет parent) рисует и часы, и виджеты.
    ctx.is_clock = True
    ctx.is_info = True

    # ash: инфо-виджеты (батарея/музыка/задачи)
    ctx.info = []
    ctx.info_font = os.getenv("XSECURELOCK_SAVER_INFO_FONT", "Cantarell")
    ctx.icon_font = os.getenv("XSECURELOCK_SAVER_ICON_FONT", "JetBrainsMono Nerd Font")
    _mh = os.path.expanduser("~/.mpd_host")
    try:
        ctx.mpd_host = (
            open(_mh).read().strip() if os.path.exists(_mh) else os.getenv("MPD_HOST")
        )
    except Exception:
        ctx.mpd_host = os.getenv("MPD_HOST")

    ctx.window = Gtk.Window()
    ctx.window.set_app_paintable(True)
    ctx.window.set_visual(ctx.window.get_screen().get_rgba_visual())
    ctx.window.connect("realize", on_win_realize, ctx)
    ctx.window.connect("draw", on_win_draw, ctx)
    ctx.window.connect("delete-event", Gtk.main_quit)

    ctx.overlay = Gtk.DrawingArea()
    ctx.overlay.connect("draw", on_overlay_draw, ctx)
    ctx.window.add(ctx.overlay)

    gio_event_args = (None, None, None, Gio.FileMonitorEvent.CHANGES_DONE_HINT)
    if ctx.background_image:
        gfile = Gio.File.new_for_path(ctx.background_image)
        monitor1 = gfile.monitor_file(Gio.FileMonitorFlags.WATCH_MOVES, None)
        monitor1.connect("changed", on_background_change, ctx)
        on_background_change(*gio_event_args, ctx)
    if ctx.weather_file:
        gfile = Gio.File.new_for_path(ctx.weather_file)
        monitor2 = gfile.monitor_file(Gio.FileMonitorFlags.WATCH_MOVES, None)
        monitor2.connect("changed", on_weather_change, ctx)
        GLib.timeout_add(1000, on_weather_change, *gio_event_args, ctx)
    GLib.timeout_add(1000, on_clock_change, ctx)
    # ash: поллинг инфо-виджетов — первый прогон ~1.5с, далее каждые 5с
    GLib.timeout_add(1500, lambda: (poll_info(ctx), False)[1])
    GLib.timeout_add(5000, poll_info, ctx)

    ctx.window.show_all()

    # Main loop
    Gtk.main()
