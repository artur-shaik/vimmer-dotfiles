#!/bin/bash
# ash: pinentry dispatcher. Backend chosen by PINENTRY_USER_DATA (gpg-agent
# forwards it from the client): interactive zsh exports =curses -> TUI requests
# (neomutt, terminal gpg/pass) go to ncurses; GUI (launched from WM, no var) ->
# fallback from ~/.gnupg/.pe = pinentry-rofi.

if [ "$PINENTRY_USER_DATA" = "tty" ]; then
    exec /usr/bin/pinentry-tty "$@"
fi

if [ "$PINENTRY_USER_DATA" = "curses" ]; then
    exec /usr/bin/pinentry-curses "$@"
fi

if [ "$PINENTRY_USER_DATA" = "qt" ]; then
    exec /usr/bin/pinentry-qt "$@"
fi

if [ "$PINENTRY_USER_DATA" = "rofi" ]; then
    exec /home/ash/bin/pinentry-rofi "$@"
fi

PINENTRY_PRG=$(cat ~/.gnupg/.pe 2>/dev/null)
if [ -z "$PINENTRY_PRG" ]; then
    # ash: fallback = GUI/WM context (interactive zsh always sets =curses, never
    # reaches here). Used to be curses -> broke in GUI without a tty ("GUI not
    # showing again"), plus .pe occasionally empties to 1 byte. rofi default =
    # GUI works even with an empty .pe.
    prg=/home/ash/bin/pinentry-rofi
else
    prg=$PINENTRY_PRG
fi

exec $prg "$@"
