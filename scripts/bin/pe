#!/bin/bash
# ash: pinentry dispatcher (gpg-agent pinentry-program).
#
# The hard problem: gpg-agent is a long-lived daemon that bakes in the
# PINENTRY_USER_DATA of whoever first spawned it and forwards that to us for
# any client that doesn't send its own. So relying on PINENTRY_USER_DATA for
# the GUI-vs-TUI split is fragile (a shell exporting =curses, or tmux-pass
# exporting =qt + updatestartuptty, poisons every later pinentry globally).
#
# Robust rule for a local X desktop: default to rofi. pinentry-rofi gets the
# client's DISPLAY via the assuan OPTION (parsed there) + a :0 fallback, so it
# works regardless of pe's own env. Explicit tty/qt/curses are still honored
# for deliberate callers; a baked-in value other than those falls through to
# rofi and can't silently break GUI prompts.

case "$PINENTRY_USER_DATA" in
    tty)    exec /usr/bin/pinentry-tty "$@" ;;
    qt)     exec /usr/bin/pinentry-qt "$@" ;;
    curses) exec /usr/bin/pinentry-curses "$@" ;;
    *)      exec /home/ash/bin/pinentry-rofi "$@" ;;
esac
