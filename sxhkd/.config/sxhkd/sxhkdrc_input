# dunst (бывшая секция [shortcuts] dunstrc — в 1.7+ только через WM)
# close — ctrl+period (НЕ ctrl+space: тот грабился глобально и ломал
# treesitter-выделение C-Space в nvim/wildfire)
ctrl + period
	dunstctl close

ctrl + shift + space
	dunstctl close-all

ctrl + grave
	dunstctl history-pop

ctrl + shift + period
	dunstctl context

# make sxhkd reload its configuration files:
super + Escape
	pkill -x sxhkd; sxhkd &;

# open alacritty terminal
super + Return
	alacritty

# toggle dropdown terminal (scratchpad, 70%x35% from top)
super + d
	OpenApps --scratch

# clipboard editor (nvim, CLIPBOARD/PRIMARY tabs, :w applies)
super + y
	clip-edit.sh

# scratch translator (tmux: left en->ru, right ru->en)
super + z
	trans-scratch.sh


super + ctrl + b
    wall_select.sh

super + ctrl + t
    theme_toggle_light.sh

# run pass menu (rofi, единая тема ash-wal)
super + ctrl + space
	~/bin/rofi-pass.sh

super + ctrl + Tab 
    rofi -show window -show-icons

# run custom menu
super + space
	rofi -show blezz -modi blezz -auto-select -matching normal -blezz-config /home/ash/.config/blezz.conf

# start terminal with ncmpcpp
super + shift + m
    alacritty --option 'window.dimensions.columns=100' --option 'window.dimensions.lines=20' -e ncmpcpp --host $(cat ~/.mpd_host);

# start terminal with elinks
super + shift + b
    unset TMUX; \
    alacritty --option 'window.dimensions.columns=80' --option 'window.dimensions.lines=25' -e tmux new-session -A -s eratys 'raty `xclip -o` | elinks' \;

# start terminal with weechat
super + shift + o
    OLDTMUX="$TMUX"; \
    unset TMUX; \
	alacritty --option 'window.dimensions.columns=130' --option 'window.dimensions.lines=28' -e tmuxinator start internet \; \
    export TMUX="$OLDTMUX";

super + shift + p
	alacritty --option 'window.dimensions.columns=100' --option 'window.dimensions.lines=20' -e bash -c 'xclip -o | vim -';

Print
	spectacle -g

shift + Print
	spectacle -r
